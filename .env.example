# ═══════════════════════════════════════════════════════════════════
# Autonomous Pothole Intelligence System — Environment Configuration
# Copy to .env and fill in real credentials
# ═══════════════════════════════════════════════════════════════════

# ─── Core ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret
DATABASE_URL=postgresql+asyncpg://pothole:pothole@db:5432/pothole_db
SYNC_DATABASE_URL=postgresql://pothole:pothole@db:5432/pothole_db
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=pothole
POSTGRES_PASSWORD=pothole
POSTGRES_DB=pothole_db

# ─── Sentinel (ESA Copernicus) ─────────────────────────────────────
SENTINEL_USER=
SENTINEL_PASS=
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# ─── ISRO Bhoonidhi (CARTOSAT / RISAT / EOS-04 / ResourceSat) ─────
BHOONIDHI_USERNAME=
BHOONIDHI_PASSWORD=

# ─── JAXA ALOS-2 ──────────────────────────────────────────────────
JAXA_AUIG2_USER=
JAXA_AUIG2_PASS=

# ─── NASA Earthdata (Landsat, MODIS, VIIRS) ───────────────────────
NASA_EARTHDATA_USER=
NASA_EARTHDATA_PASS=
USGS_USERNAME=
USGS_PASSWORD=
USGS_M2M_API_KEY=

# ─── Google Earth Engine ───────────────────────────────────────────
GEE_SERVICE_ACCOUNT_KEY_PATH=/secrets/gee_key.json

# ─── Gemini AI ─────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Weather ───────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=

# ─── PG Portal ─────────────────────────────────────────────────────
PG_PORTAL_USER=
PG_PORTAL_PASS=

# ─── data.gov.in ──────────────────────────────────────────────────
DATAGOVIN_API_KEY=

# ─── Mapillary ─────────────────────────────────────────────────────
MAPILLARY_ACCESS_TOKEN=

# ─── NRSC Data ─────────────────────────────────────────────────────
NRSC_DATA_USERNAME=
NRSC_DATA_PASSWORD=

# ─── SMTP ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── MinIO Object Storage ─────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000

# ─── Mapbox (Frontend) ────────────────────────────────────────────
VITE_MAPBOX_TOKEN=
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=http://localhost:8000

# ─── Grafana ──────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin

# ─── SNAP ──────────────────────────────────────────────────────────
SNAP_HOME=/opt/snap
