CELERY_CONCURRENCY=4

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
SECRET_KEY=your-super-secret-key-change-in-production
JWT_EXPIRY_HOURS=1
JWT_REFRESH_EXPIRY_DAYS=7

# CORS Configuration
