PUBLIC_DASHBOARD_URL=http://localhost:3001
MOBILE_APP_URL=http://localhost:8081

# Feature Flags
ENABLE_SATELLITE_INGESTION=false
ENABLE_DRONE_PROCESSING=false
ENABLE_CCTV_INFERENCE=true
ENABLE_AUTO_FILING=false
ENABLE_ESCALATION=true
ENABLE_REPAIR_VERIFICATION=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Environment
ENVIRONMENT=development
DEBUG=true
