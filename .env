DETECTION_NMS_IOU=0.45
DETECTION_IMG_SIZE=1024
DEPTH_CALIB_FACTOR=0.15
AUTO_FILE_RISK_THRESHOLD=65.0

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
